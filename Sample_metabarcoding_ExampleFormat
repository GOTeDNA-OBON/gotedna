### This code can be used to format bioinformatic output data from metabarcoding into the Sample_metabarcoding template files

# Open packages and load libraries
install.packages("openxlsx")
install.packages("dplyr")
install.packages("tidyr")
install.packages("worrms")

library(readxl)
library(openxlsx)
library(readr)
library(dplyr)
library(tidyr)
library(worrms)
library(stringr)
library(purrr)

# Read in excel files
data1 <- read_csv("Bioinformatic_output_COI.csv")
data2 <- read_csv("Bioinformatic_output_18S.csv")

# Filter dataframe so that there are no NA_character_ values in species column
data1 <- data1 %>%
  filter(!is.na(species))


# Create df with GOTeDNA columns (see example templates) and add rows for species names from bioinformatic output file (xlsx/csv)

df_data1 <- data.frame(
  protocol_ID = character(length(data1$species)),
  protocolVersion = character(length(data1$species)),
  basisOfRecord = "MaterialSample",
  materialSampleID = character(length(data1$species)),
  samp_name = character(length(data1$species)),
  samp_category = "sample",
  neg_cont_type = "NA",
  pos_cont_type = "NA",
  technical_rep_id = character(length(data1$species)),
  eventID = character(length(data1$species)),
  eventDate = character(length(data1$species)),
  year = character(length(data1$species)),
  month = character(length(data1$species)),
  recordedBy = character(length(data1$species)),
  assay_name = character(length(data1$species)),
  target_gene = character(length(data1$species)),
  target_subfragment = character(length(data1$species)),
  targetTaxonomicAssay = character(length(data1$species)),
  scientificName = data1$species,
  kingdom = character(length(data1$species)),
  phylum = character(length(data1$species)),
  class = character(length(data1$species)),
  order = character(length(data1$species)),
  family = character(length(data1$species)),
  genus = character(length(data1$species)),
  occurrenceID = character(length(data1$species)),
  organismQuantity = numeric(length(data1$species)),
  organismQuantityType = "DNA sequence reads",
  checkls_ver = "1.0.2",
  taxonID = character(length(data1$species)),
  sampleSizeValue = character(length(data1$species)),
  sampleSizeUnit = character(length(data1$species)),
  samplingProtocol = character(length(data1$species)),
  associatedSequences = character(length(data1$species)),
  identificationRemarks = character(length(data1$species)),
  stringsAsFactors = FALSE
)

# View dataframe
View(df_data1)

# Pivot from wide (samples as columns) to long (sample, value)
# Linking bioinformatic output to GOTeDNA file format
df_data1 <- data1 %>%
  pivot_longer(
    cols = -c(species, phylum, class, order, family, genus),   # keep species fixed, everything else pivots
    names_to = "materialSampleID",
    values_to = "organismQuantity"
  ) %>%
  filter(organismQuantity > 0,    #remove zero values
         !grepl("_species\\.", species)     #remove genus_species. names
  ) %>%
  mutate(
    protocol_ID = "26",
    protocolVersion = "1",
    basisOfRecord = "MaterialSample",

    samp_name = materialSampleID,
    samp_category = "sample",
    neg_cont_type = "NA",
    pos_cont_type = "NA",
    technical_rep_id = NA_character_,
    eventID = paste(protocol_ID, materialSampleID, sep = "-"),
    eventDate = NA_character_,
    year = NA_character_,
    month = NA_character_,
    recordedBy = NA_character_,
    assay_name = NA_character_,
    target_gene = "COI",
    target_subfragment = NA_character_,
    targetTaxonomicAssay = NA_character_,
    scientificName = species,
    kingdom = NA_character_,
    occurrenceID = paste(protocol_ID, materialSampleID, target_gene, substr(genus, 1, 4), sep = "-"),

    organismQuantityType = "DNA sequence reads",
    checkls_ver = "1.0.2",
    taxonID = NA_character_,
    sampleSizeValue = NA_character_,
    sampleSizeUnit = NA_character_,
    samplingProtocol = NA_character_,
    associatedSequences = NA_character_,
    identificationRemarks = NA_character_,
  ) %>%
  select(
    protocol_ID, protocolVersion, basisOfRecord, materialSampleID, samp_name, samp_category,
    neg_cont_type, pos_cont_type, technical_rep_id, eventID, eventDate, year, month,
    recordedBy, assay_name, target_gene, target_subfragment, targetTaxonomicAssay, scientificName,
    kingdom, phylum, class, order, family, genus, occurrenceID,
    organismQuantity, organismQuantityType, checkls_ver, taxonID, sampleSizeValue, sampleSizeUnit,
    samplingProtocol, associatedSequences, identificationRemarks
  )


